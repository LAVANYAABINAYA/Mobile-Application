}


package com.example.ex;

import android.os.Bundle;
import android.view.View;
import android.widget.Button;
import android.widget.TextView;
import androidx.appcompat.app.AppCompatActivity;

public class QuizActivity extends AppCompatActivity {

    private String[] questions = {
            "1. Java is a purely object-oriented programming language?",
            "2. In Python, indentation is used to define code blocks?",
            "3. HTML is a programming language?",
            "4. 'HTTP' stands for HyperText Transfer Protocol?",
            "5. An Array's index starts at 1 in most languages?",
            "6. SQL is used for managing relational databases?",
            "7. JavaScript is the same as Java?",
            "8. A 'Boolean' variable can have three possible values?",
            "9. Git is a version control system?",
            "10. The 'if' statement is used for iteration (looping)?"
    };

    private boolean[] answers = {true, true, false, true, false, true, false, false, true, false};
    private int score = 0;
    private int currentQuestionIndex = 0;

    private TextView questionTextView;
    private Button trueButton, falseButton, submitButton;

    @Override
    protected void onCreate(Bundle savedInstanceState) {
        super.onCreate(savedInstanceState);
        setContentView(R.layout.activity_quiz);

        questionTextView = findViewById(R.id.questionTextView);
        trueButton = findViewById(R.id.trueButton);
        falseButton = findViewById(R.id.falseButton);
        submitButton = findViewById(R.id.submitButton);

        displayQuestion();

        trueButton.setOnClickListener(new View.OnClickListener() {
            @Override
            public void onClick(View v) {
                if (answers[currentQuestionIndex]) score++;
                currentQuestionIndex++;
                displayQuestion();
            }
        });

        falseButton.setOnClickListener(new View.OnClickListener() {
            @Override
            public void onClick(View v) {
                if (!answers[currentQuestionIndex]) score++;
                currentQuestionIndex++;
                displayQuestion();
            }
        });

        submitButton.setOnClickListener(new View.OnClickListener() {
            @Override
            public void onClick(View v) {
                // Show score
                // You might want to use a dialog or another activity to show the score
                setContentView(R.layout.activity_score);
                TextView scoreView = findViewById(R.id.scoreTextView);
                scoreView.setText("Your score: " + score + "/10");
            }
        });
    }

    private void displayQuestion() {
        if (currentQuestionIndex < questions.length) {
            questionTextView.setText(questions[currentQuestionIndex]);
        } else {
            // No more questions, display score or reset
            finish();
        }
    }
}
